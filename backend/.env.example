PORT=5000
# MongoDB Atlas: use your connection string and add /Blogapp before ? for database name
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/Blogapp?appName=...
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/Blogapp?appName=...
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=production
# Frontend origin for CORS - set this to your deployed frontend URL
CORS_ORIGIN=https://your-frontend-vercel-url.vercel.app
